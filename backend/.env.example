# Backend environment variables

# Firebase service account JSON (Cloud Run では Secret Manager から自動注入)
# ローカル開発時はJSONファイルのパスまたはJSON文字列を設定
FIREBASE_SERVICE_ACCOUNT=

# Frontend site origin for CORS (e.g. https://kodomo-wallet-frontend-xxx-an.a.run.app)
FRONTEND_ORIGIN=

# App security
SECRET_KEY=

# Environment
ENVIRONMENT=production
